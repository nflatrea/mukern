Implementation Strategy
1. The Generic Interface (include/hal.h)

Define the minimal API required by the kernel. This file acts as a dispatcher, including the correct 
architecture-specific implementation based on the build target.

/* include/hal.h */
#pragma once

#if defined(ARCH_arm64)
    #include "arch/arm64/hal/uart.h"
    #include "arch/arm64/hal/gic.h"
#elif defined(ARCH_x86_64)
    #include "arch/x86_64/hal/uart.h"
    #include "arch/x86_64/hal/apic.h"
#endif

/* Generic Kernel API */
static inline void hal_console_putc(char c) {
    arch_uart_putc(c); // Resolves to arch-specific static inline
}

static inline void hal_irq_enable(void) {
    arch_irq_enable();
}
 

2. Struct-Based Register Definition (arch/x86_64/hal/uart.h)

Instead of magic numbers, define the hardware layout using volatile structs. This matches the "Bare Metal" 
best practices found in modern embedded design.

/* arch/x86_64/hal/uart.h */
#pragma once
#include <stdint.h>

#define UART_BASE 0x3F8

/* Hardware Register Map */
typedef struct {
    volatile uint8_t data;    // 0x00: Data register
    volatile uint8_t ier;     // 0x01: Interrupt Enable
    volatile uint8_t fcr;     // 0x02: FIFO Control
    volatile uint8_t lcr;     // 0x03: Line Control
    volatile uint8_t mcr;     // 0x04: Modem Control
    volatile uint8_t lsr;     // 0x05: Line Status
} uart_regs_t;

/* Map struct to physical address */
static inline uart_regs_t* uart_get_regs(void) {
    return (uart_regs_t*)UART_BASE;
}

/* HAL Implementation (Static Inline for Zero Overhead) */
static inline void arch_uart_putc(char c) {
    uart_regs_t* regs = uart_get_regs();
    // Wait until Transmit Holding Register is empty
    while ((regs->lsr & 0x20) == 0); 
    regs->data = c;
}

static inline void arch_uart_init(void) {
    uart_regs_t* regs = uart_get_regs();
    regs->lcr = 0x03; // 8-bit, no parity
    regs->fcr = 0x00; // Disable FIFO
    regs->mcr = 0x00; // No modem control
}
 

3. Memory-Mapped I/O Helpers (arch/*/hal/mmio.h)

Ensure correct memory ordering. Compilers may optimize away repeated reads/writes to hardware registers. Use volatile and explicit barriers.

/* arch/arm64/hal/mmio.h */
#pragma once
#include <stdint.h>

/* Force compiler to not optimize access */
static inline uint32_t mmio_read32(uintptr_t addr) {
    return *(volatile uint32_t*)addr;
}

static inline void mmio_write32(uintptr_t addr, uint32_t val) {
    *(volatile uint32_t*)addr = val;
    __asm__ volatile("dsb sy" ::: "memory"); // ARM Data Synchronization Barrier
}
 

Key Design Decisions
Feature	Suckless Approach	Traditional Approach	Why?
Dispatch	#ifdef / Static Inline	Function Pointers / Vtables	Eliminates indirection overhead; critical for IPC/Interrupts.
State	Stateless	Object Instances (struct Device*)	Kernel hardware is singleton; no need for dynamic allocation.
Error Handling	Panic / Spin	Return Codes	HAL failures are fatal kernel bugs; do not propagate errors up.
Concurrency	Interrupt Disable	Spinlocks	HAL is called during boot/interrupts where locks may not exist yet.
